## \file
## lit.site.cfg.py.in - CMake-configured site config for lit tests.

import os

config.arcanum_src_root = "@CMAKE_SOURCE_DIR@"
config.arcanum_obj_root = "@CMAKE_BINARY_DIR@"
config.arcanum_tools_dir = "@CMAKE_BINARY_DIR@/tools"
config.llvm_tools_dir = "@LLVM_TOOLS_BINARY_DIR@"

# Let the main config do the real work.
lit_config.load_config(
    config,
    os.path.join(config.arcanum_src_root, "test", "lit.cfg.py"))
